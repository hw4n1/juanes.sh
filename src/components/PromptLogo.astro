---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class:list={['prompt-logo', className]}>
  <span class="path">~/juanes</span>
  <span class="symbol">$</span>
  <span class="cursor" aria-hidden="true"></span>
</span>

<style>
  .prompt-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-weight: 500;
    white-space: nowrap;
  }

  .path {
    color: var(--ink-900);
  }

  .symbol {
    color: var(--accent);
  }

  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 1em;
    background: var(--brand-accent);
    animation: blink 1s step-end infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
    }
  }

  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }
</style>
