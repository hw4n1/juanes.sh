---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getPublishedPosts } from '../utils/posts';

const posts = await getPublishedPosts();
const recentPosts = posts.slice(0, 5);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} canonicalURL={new URL('/', Astro.site)}>
  <section class="hero">
    <p class="prompt-prefix" aria-hidden="true">$ whoami</p>
    <h1>Juan Esteban Muñoz Díaz</h1>
    <p class="lead measure">
      Application security engineer who runs his own homelab — Proxmox cluster, my own DNS, Prometheus/Grafana
      observability — and is getting his own ASN and IPv6 via LACNIC. I write about networking, infrastructure,
      BGP/ASN, privacy, homelab, and security.
    </p>
    <p class="links">
      <a href="/about/">about me</a>
      <span aria-hidden="true">·</span>
      <a href="/blog/">read the blog</a>
    </p>
  </section>

  <section class="recent">
    <h2 class="section-title">$ ls posts/ --recent</h2>
    {
      recentPosts.length > 0 ? (
        <div class="post-list">
          {recentPosts.map((post) => <PostCard post={post} />)}
        </div>
      ) : (
        <p class="empty">No posts published yet.</p>
      )
    }
    {posts.length > 5 && <a class="view-all" href="/blog/">view all posts →</a>}
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 56rem;
    margin: 0 auto;
    padding: 3.5rem 1.25rem 2.5rem;
  }

  .prompt-prefix {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    margin-bottom: 0.6rem;
  }

  h1 {
    font-size: var(--text-4xl);
  }

  .lead {
    margin-top: 1.1rem;
    font-size: var(--text-lg);
    color: var(--ink-700);
  }

  .links {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    display: flex;
    gap: 0.6rem;
  }

  .links a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
  }

  .recent {
    max-width: 56rem;
    margin: 0 auto;
    padding: 1rem 1.25rem 4rem;
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink-500);
    text-transform: lowercase;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.85rem;
  }

  .empty {
    color: var(--ink-500);
    padding: 1.5rem 0;
  }

  .view-all {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
  }
</style>
